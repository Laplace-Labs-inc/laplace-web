# astro public site — build-time environment contract (FABLE-032)
#
# Copy to `.env.local` (gitignored) and fill in to enable the features below.
# All vars use the PUBLIC_ prefix and are therefore inlined into client JS at
# build time — only put public-safe values here. Never commit `.env.local`.
#
# When a feature's vars are unset, the feature degrades to an HONEST explicit
# gate (visibly disabled / "coming soon"), never a silently-broken stub.

# --- Waitlist (astro/src/components/landing/WaitlistForm.tsx) ---
# HTTPS endpoint that accepts POST with JSON body {"email":"..."} and returns
# 2xx on success (e.g. Formspree/Buttondown, or the laplace-api waitlist route).
# Public POST URL — not a secret. Leave unset to keep the waitlist gated.
PUBLIC_WAITLIST_ENDPOINT=

# --- Docs search / Algolia DocSearch (astro/src/components/Search.astro) ---
# All three required to enable search; leave any unset to keep search gated.
PUBLIC_ALGOLIA_APP_ID=
# Search-ONLY API key (public-safe). Do NOT use an admin/write key.
PUBLIC_ALGOLIA_SEARCH_KEY=
PUBLIC_ALGOLIA_INDEX_NAME=
