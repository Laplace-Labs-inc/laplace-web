# Laplace console (frontend) — build-time configuration.
# Copy to `.env` and fill in per deployment. All VITE_* vars are embedded in the
# client bundle, so only put *public* values here (never client secrets).

# Control-plane base URL (laplace-api). Leave empty to render a "not connected" console.
VITE_API_BASE_URL=

# GitHub OAuth App client id (public). Required for the "Continue with GitHub" button.
VITE_GITHUB_CLIENT_ID=

# Redirect URI registered on the GitHub OAuth App. Defaults to <origin>/auth/callback.
VITE_OAUTH_REDIRECT_URI=

# "true" exposes the dev email sign-in. Only works when the backend is started with
# OAUTH_DEV_ALLOW_UNVERIFIED=true. Never enable in production.
VITE_OAUTH_DEV=

# ─────────────────────────────────────────────────────────────────────────────
# OWNER-gated go-live tail (not configurable here — these live in the backend /
# infra, see laplace-cloud task #5 Staging/prod infra):
#   1. Deploy laplace-api with a reachable VITE_API_BASE_URL origin.
#   2. Set API_CORS_ORIGIN on laplace-api to this frontend's origin.
#   3. Register a GitHub OAuth App; put its client id in VITE_GITHUB_CLIENT_ID
#      and its client secret on the backend.
#   4. Add the backend OAuth code->token callback route. The existing
#      POST /api/v1/auth/oauth/exchange expects an already-verified provider
#      token; the SPA sends the `code`, so the backend must complete the
#      GitHub code exchange before issuing the session. Until then, use
#      VITE_OAUTH_DEV=true for local end-to-end testing.
