---
import { getCollection, getEntry, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";

interface Props {
  entryId: CollectionEntry<"docs">["id"];
  currentSlug: string;
}

export const getStaticPaths = async () => {
  const docs = await getCollection("docs");
  return docs.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, "") },
    props: {
      entryId: entry.id,
      currentSlug: entry.id.replace(/\.mdx?$/, ""),
    },
  }));
};

const { entryId, currentSlug } = Astro.props as Props;
const entry = await getEntry("docs", entryId);
if (!entry) {
  throw new Error(`Doc entry not found for id: ${entryId}`);
}
const { Content, headings } = await render(entry);
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  headings={headings}
  currentSlug={currentSlug}
>
  <Content />
</DocsLayout>
