---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { docsNav } from "../../data/docs-nav";

const sections = docsNav;
---

<DocsLayout
  title="Documentation"
  description="Laplace documentation hub — Getting Started, Concepts, Tasks, and Reference."
  headings={[]}
  currentSlug=""
>
  <h1>Documentation</h1>
  <p>
    Welcome to the Laplace documentation. Pick a section below or open the
    sidebar to jump straight into a topic.
  </p>

  <div class="not-prose mt-10 grid gap-6 sm:grid-cols-2">
    {sections.map((section) => {
      const first = section.items[0];
      return (
        <a
          href={`/docs/${first.slug}/`}
          class="group block rounded-lg border border-brand-border bg-brand-surface/40 p-6 transition-colors hover:border-brand-accent"
        >
          <p class="text-xs font-semibold uppercase tracking-wider text-brand-muted">
            {section.icon} {section.section}
          </p>
          <h2 class="mt-2 text-lg font-semibold text-fg">
            {first.title}
          </h2>
          <ul class="mt-3 space-y-1 text-sm text-brand-muted">
            {section.items.slice(0, 4).map((item) => (
              <li class="flex items-center gap-2">
                <span class="h-1 w-1 rounded-full bg-brand-muted/60" />
                <span class="group-hover:text-fg">{item.title}</span>
              </li>
            ))}
          </ul>
        </a>
      );
    })}
  </div>

  <h2>Quick Start</h2>
  <p>
    New here? The <a href="/docs/getting-started/">Quickstart</a> walks you
    from install to your first verification in under five minutes. Then dive
    into the <a href="/docs/concepts/axiom/">Axiom DPOR+POR engine</a> to see
    how Laplace finds deadlocks that other tools miss.
  </p>

  <h2>Beyond the docs</h2>
  <p>
    Read about real bugs we have surfaced in production libraries on the
    <a href="/blog/case-studies/">Case Studies</a> page, or see how Laplace
    benchmarks against Loom, Shuttle, Stateright, and madsim on the
    <a href="/vs/benchmarks/">Benchmark Comparison</a> page.
  </p>
</DocsLayout>
