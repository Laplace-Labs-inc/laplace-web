---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
const h2 = headings.filter((h) => h.depth === 2);
---

{
  h2.length > 0 && (
    <aside
      class="hidden xl:block w-56 shrink-0 sticky top-16 h-[calc(100vh-4rem)]
           overflow-y-auto py-8 pl-6"
    >
      <p class="text-xs font-semibold uppercase tracking-wider text-brand-muted mb-3">
        On This Page
      </p>
      <nav>
        <ul class="space-y-1" id="toc-list">
          {h2.map((h) => (
            <li>
              <a
                href={`#${h.slug}`}
                data-toc-id={h.slug}
                class="block text-sm text-brand-muted hover:text-fg transition-colors py-0.5"
              >
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )
}

<script>
  // 현재 섹션 하이라이트 (IntersectionObserver)
  const tocLinks = document.querySelectorAll("[data-toc-id]");
  const headingEls = Array.from(tocLinks).map((link) => {
    const id = link.getAttribute("data-toc-id");
    return id ? document.getElementById(id) : null;
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          tocLinks.forEach((l) =>
            l.classList.remove("text-brand-accent", "font-medium")
          );
          const id = entry.target.getAttribute("id");
          const link = id ? document.querySelector(`[data-toc-id="${id}"]`) : null;
          link?.classList.add("text-brand-accent", "font-medium");
        }
      });
    },
    { rootMargin: "-20% 0% -70% 0%" }
  );

  headingEls.forEach((el) => el && observer.observe(el));
</script>
