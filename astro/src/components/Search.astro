---
interface Props {
  placeholder?: string;
}

const { placeholder = "Search docs" } = Astro.props;
const enabled = Boolean(
  import.meta.env.PUBLIC_ALGOLIA_APP_ID &&
    import.meta.env.PUBLIC_ALGOLIA_SEARCH_KEY &&
    import.meta.env.PUBLIC_ALGOLIA_INDEX_NAME,
);
---

<div class="doc-search" data-enabled={enabled ? "true" : "false"}>
  <label class="doc-search__fallback">
    <span class="sr-only">{placeholder}</span>
    <input type="search" placeholder={enabled ? "DocSearch registration pending" : placeholder} disabled />
  </label>
</div>

<style>
  .doc-search {
    width: 100%;
  }

  .doc-search__fallback input {
    width: 100%;
    border: 1px solid var(--color-border, #2a2a2a);
    border-radius: 6px;
    background: var(--color-surface, #111);
    color: inherit;
    padding: 0.625rem 0.75rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
