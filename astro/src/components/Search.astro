---
// FABLE-032: docs search.
// REAL connection via Algolia DocSearch when the three PUBLIC_ALGOLIA_* env vars
// are configured at build time; HONEST explicit gate (disabled, "coming soon")
// when any is missing — never a silently-broken search box.
//
// Env contract (see astro/.env.example):
//   PUBLIC_ALGOLIA_APP_ID     — Algolia application id
//   PUBLIC_ALGOLIA_SEARCH_KEY — Algolia *search-only* API key (public-safe;
//                               do NOT use an admin/write key here)
//   PUBLIC_ALGOLIA_INDEX_NAME — DocSearch index name
interface Props {
  placeholder?: string;
}

const { placeholder = "Search docs" } = Astro.props;
const enabled = Boolean(
  import.meta.env.PUBLIC_ALGOLIA_APP_ID &&
    import.meta.env.PUBLIC_ALGOLIA_SEARCH_KEY &&
    import.meta.env.PUBLIC_ALGOLIA_INDEX_NAME,
);
---

<div class="doc-search">
  {
    enabled ? (
      <div id="docsearch" />
    ) : (
      <label class="doc-search__fallback">
        <span class="sr-only">{placeholder}</span>
        <input type="search" placeholder={`${placeholder} (coming soon)`} disabled aria-disabled="true" />
      </label>
    )
  }
</div>

<script>
  // Guard on PUBLIC_ env vars: when unset they are statically inlined as
  // `undefined`, so the condition is false at build time and the dynamic
  // imports are tree-shaken out (no DocSearch JS/CSS shipped on the gated path).
  const appId = import.meta.env.PUBLIC_ALGOLIA_APP_ID;
  const apiKey = import.meta.env.PUBLIC_ALGOLIA_SEARCH_KEY;
  const indexName = import.meta.env.PUBLIC_ALGOLIA_INDEX_NAME;

  if (appId && apiKey && indexName && document.getElementById("docsearch")) {
    const { default: docsearch } = await import("@docsearch/js");
    await import("@docsearch/css");
    docsearch({
      container: "#docsearch",
      appId,
      apiKey,
      indexName,
    });
  }
</script>

<style>
  .doc-search {
    width: 100%;
  }

  .doc-search__fallback input {
    width: 100%;
    border: 1px solid var(--color-border, #2a2a2a);
    border-radius: 6px;
    background: var(--color-surface, #111);
    color: inherit;
    padding: 0.625rem 0.75rem;
    cursor: not-allowed;
    opacity: 0.6;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
