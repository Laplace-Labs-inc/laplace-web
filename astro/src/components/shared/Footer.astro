---
const year = new Date().getFullYear();
---
<footer class="mt-32 border-t border-brand-border">
  <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-6 py-12 md:flex-row">
    <img src="/images/Laplace_labs.svg" alt="Laplace Labs" class="h-8 w-auto dark:invert dark:brightness-90" />
    <p class="text-sm text-brand-muted">© {year} Laplace Labs Inc. All rights reserved.</p>
    <div class="flex flex-wrap justify-center gap-6 text-sm text-brand-muted">
      <a href="https://docs.laplace-labs.com/" class="transition-colors hover:text-fg">Docs</a>
      <a href="/blog/case-studies/" class="transition-colors hover:text-fg">Case Studies</a>
      <a href="/vs/benchmarks/" class="transition-colors hover:text-fg">Benchmarks</a>
      <a href="/pricing" class="transition-colors hover:text-fg">Pricing</a>
      <a href="https://github.com/Laplace-Labs-inc" target="_blank" rel="noreferrer" class="transition-colors hover:text-fg">GitHub</a>
    </div>
  </div>
</footer>
