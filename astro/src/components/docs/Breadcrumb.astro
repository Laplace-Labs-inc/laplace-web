---
interface Props {
  slug: string;
}
const { slug } = Astro.props;

const parts = [
  "Docs",
  ...slug.split("/").map((s) =>
    s
      .split("-")
      .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
      .join(" ")
  ),
];
---

<nav class="flex items-center gap-1.5 text-sm text-brand-muted mb-6">
  {
    parts.map((part, i) => (
      <>
        {i > 0 && <span class="text-brand-border">/</span>}
        <span class:list={[i === parts.length - 1 ? "text-fg" : "hover:text-fg cursor-pointer"]}>
          {part}
        </span>
      </>
    ))
  }
</nav>
