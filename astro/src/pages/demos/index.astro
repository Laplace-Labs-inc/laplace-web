---
import { readFileSync } from "node:fs";
import { join } from "node:path";
import Base from "../../layouts/Base.astro";
import Nav from "../../components/shared/Nav.astro";
import Footer from "../../components/shared/Footer.astro";

const demos = [
  {
    title: "Quickstart 30s",
    duration: "30s",
    file: "/assets/demos/quickstart-30s.cast",
    summary: "Install the release candidate, initialize a BYOC project, and detect ABBA.",
  },
  {
    title: "BYOC Integration 60s",
    duration: "60s",
    file: "/assets/demos/byoc-integration-60s.cast",
    summary: "Patch a hyper-style connection pool with TrackedMutex and verify the deadlock.",
  },
  {
    title: "Forensic View 45s",
    duration: "45s",
    file: "/assets/demos/forensic-view-45s.cast",
    summary: "Open a .ard artifact and inspect the lock cycle that closes the failure.",
  },
  {
    title: "Probe Integration 60s",
    duration: "60s",
    file: "/assets/demos/probe-integration-60s.cast",
    summary: "Turn live probe traffic into a deterministic verification seed.",
  },
  {
    title: "Kraken Load 90s",
    duration: "90s",
    file: "/assets/demos/kraken-load-90s.cast",
    summary: "Run a deterministic 100 VU load scenario and capture the replay seed.",
  },
];

function transcriptFor(file: string): string {
  const castPath = join(process.cwd(), "public", file);
  const lines = readFileSync(castPath, "utf8").trim().split("\n").slice(1);
  return lines
    .map((line) => JSON.parse(line)[2] as string)
    .join("")
    .replace(/\u001b\[[0-9;]*[A-Za-z]/g, "")
    .replace(/\r/g, "")
    .trim();
}
---
<Base
  title="Demos"
  description="Laplace demo assets for quickstart, BYOC, forensic replay, probe integration, and Kraken load."
>
  <Nav />
  <main class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:py-16">
    <section class="border-b border-brand-border pb-10">
      <p class="mb-3 font-mono text-xs font-medium uppercase text-brand-accent">LQ-4 Demo Assets</p>
      <h1 class="max-w-4xl text-4xl font-black leading-tight md:text-5xl">
        Terminal demos for deterministic concurrency verification
      </h1>
      <p class="mt-4 max-w-3xl text-base leading-7 text-brand-muted md:text-lg">
        Five asciinema v2 casts covering the launch-critical path from first install to live trace replay.
      </p>
    </section>

    <section class="grid gap-5 py-10 md:grid-cols-2">
      {demos.map((demo) => (
        <article class="min-w-0 border border-brand-border bg-brand-surface/60 p-5">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-xl font-bold">{demo.title}</h2>
              <p class="mt-2 text-sm leading-6 text-brand-muted">{demo.summary}</p>
            </div>
            <span class="shrink-0 border border-brand-border px-2 py-1 font-mono text-xs text-brand-accent">
              {demo.duration}
            </span>
          </div>
          <div class="mt-5 max-h-64 max-w-full overflow-auto border border-brand-border bg-bg p-4">
            <pre class="whitespace-pre-wrap break-all font-mono text-xs leading-5 text-brand-muted">{transcriptFor(demo.file)}</pre>
          </div>
          <a
            href={demo.file}
            class="mt-4 inline-flex font-mono text-xs font-medium uppercase text-brand-accent transition-colors hover:text-fg"
          >
            Download cast
          </a>
        </article>
      ))}
    </section>
  </main>
  <Footer />
</Base>
