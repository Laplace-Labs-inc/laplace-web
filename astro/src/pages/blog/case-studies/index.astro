---
import Base from "../../../layouts/Base.astro";
import Nav from "../../../components/shared/Nav.astro";
import Footer from "../../../components/shared/Footer.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("caseStudies");
entries.sort(
  (a, b) => a.data.publishedAt.getTime() - b.data.publishedAt.getTime(),
);
---

<Base
  title="Case Studies"
  description="Real concurrency bugs Laplace surfaces in tokio, parking_lot, rayon, and more — each with minimal repro and forensic trace."
>
  <Nav />

  <main class="mx-auto max-w-5xl px-6 pb-20 pt-14 lg:px-10">
    <section class="border-b border-brand-border pb-8">
      <p class="font-mono text-xs font-medium uppercase tracking-[0.18em] text-brand-accent">
        Case Studies
      </p>
      <h1 class="mt-4 max-w-3xl text-4xl font-extrabold leading-tight md:text-5xl">
        Bugs Laplace finds that production CI did not
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-7 text-brand-muted md:text-lg">
        Each study reproduces a real deadlock or starvation pattern Laplace
        surfaced under Ki-DPOR exhaustive verification — with the trace, the
        minimal repro, and the upstream notification status.
      </p>
    </section>

    <ul class="mt-10 grid gap-6 md:grid-cols-2">
      {entries.map((entry) => {
        const published = entry.data.publishedAt.toISOString().slice(0, 10);
        return (
          <li>
            <a
              href={`/blog/case-studies/${entry.data.slug}/`}
              class="group block h-full rounded-lg border border-brand-border bg-brand-surface/40 p-6 transition-colors hover:border-brand-accent"
            >
              <p class="font-mono text-xs uppercase tracking-wider text-brand-muted">
                {entry.data.library} • {published}
              </p>
              <h2 class="mt-3 text-xl font-semibold text-white group-hover:text-brand-accent">
                {entry.data.title}
              </h2>
              <p class="mt-3 text-sm leading-6 text-brand-muted">
                {entry.data.description}
              </p>
              <div class="mt-5 flex flex-wrap gap-2 text-xs text-brand-muted">
                {entry.data.tags.slice(0, 4).map((tag) => (
                  <span class="rounded-full border border-brand-border px-2 py-0.5 font-mono">
                    {tag}
                  </span>
                ))}
              </div>
            </a>
          </li>
        );
      })}
    </ul>

    <section class="mt-16 rounded-lg border border-brand-border bg-brand-surface/30 p-8">
      <h2 class="text-lg font-semibold text-white">Want to compare tools head-to-head?</h2>
      <p class="mt-2 max-w-2xl text-sm text-brand-muted">
        See the same five scenarios run on Loom, Shuttle, Stateright, and madsim on the
        <a href="/vs/benchmarks/" class="font-medium text-brand-accent hover:underline">Benchmark Comparison</a>
        page.
      </p>
    </section>
  </main>

  <Footer />
</Base>
