---
import ThemeToggle from "./ThemeToggle.astro";
const links = [
  { label: "Docs", href: "https://docs.laplace-labs.com/" },
  { label: "Case Studies", href: "/blog/case-studies/" },
  { label: "Benchmarks", href: "/vs/benchmarks/" },
  { label: "Pricing", href: "/pricing" },
  { label: "GitHub", href: "https://github.com/Laplace-Labs-inc", external: true },
];
---
<header class="sticky top-0 z-50 border-b border-brand-border bg-brand-bg/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center">
      <img src="/images/Laplace_labs.svg" alt="Laplace Labs" class="h-12 w-auto object-contain dark:invert dark:brightness-90" />
    </a>

    <nav class="hidden items-center gap-8 text-sm font-medium text-brand-muted md:flex">
      {links.map((l) => (
        <a
          href={l.href}
          target={l.external ? "_blank" : undefined}
          rel={l.external ? "noreferrer" : undefined}
          class="transition-colors hover:text-fg"
        >
          {l.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <ThemeToggle />
      <a
        href="#waitlist"
        class="rounded-full bg-accent px-5 py-2 text-sm font-semibold text-accent-fg transition-opacity hover:opacity-90"
      >
        Join Waitlist -&gt;
      </a>
    </div>
  </div>
</header>
