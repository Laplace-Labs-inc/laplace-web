---
import { WaitlistForm } from "./WaitlistForm";
---
<section id="waitlist" class="mx-auto max-w-4xl px-6 py-24 text-center">
  <h2 class="mb-4 text-4xl font-bold tracking-tight md:text-5xl">
    Beta opens <span class="text-brand-accent">October 2026.</span>
  </h2>
  <p class="mx-auto mb-10 max-w-xl text-xl text-brand-muted">
    Join the waitlist. Get early access to Axiom before public launch.
    Free tier included.
  </p>
  <WaitlistForm client:load />
</section>
